# ─────────────────────────────────────────────────────────────
# QuickCart (Storefront) — environment variables
# Copy this file to `.env` and fill in the real value.
# ─────────────────────────────────────────────────────────────

# Base URL of the EcommerceCloud admin API for THIS store.
# Format: <admin-origin>/api/<storeId>
#   Local dev : http://localhost:3000/api/<storeId>
#   Production: https://your-admin.vercel.app/api/<storeId>
# The <storeId> is printed by the admin's seed script and shown in the
# admin dashboard under Settings (the "NEXT_PUBLIC_API_URL" API alert).
NEXT_PUBLIC_API_URL=http://localhost:3000/api/your-store-id
